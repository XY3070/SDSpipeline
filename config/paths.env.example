## Copy this file to SDSpipeline/config/paths.env and edit per server.
## This local file must stay untracked.

export SDSLOG_ROOT="/abs/path/to/SDSlog"
export SDS_PIPELINE_ROOT="/abs/path/to/SDSpipeline"
export SDS_WORKSPACE_ROOT="/abs/path/to/SDSworkspace"

export SDS_INPUT_ROOT="${SDS_WORKSPACE_ROOT}/input"
export SDS_RESULTS_ROOT="${SDS_WORKSPACE_ROOT}/results"
export SDS_RUNS_ROOT="${SDS_WORKSPACE_ROOT}/runs"
export SDS_ONEOFF_ROOT="${SDS_WORKSPACE_ROOT}/oneoff"
export SDS_PROVENANCE_ROOT="${SDS_WORKSPACE_ROOT}/provenance"
export SDS_CACHE_ROOT="${SDS_WORKSPACE_ROOT}/cache"
export SDS_TMP_ROOT="${SDS_WORKSPACE_ROOT}/tmp"
export SDS_EXTERNAL_ROOT="${SDS_WORKSPACE_ROOT}/external"

export SDS_VCF_ROOT="${SDS_INPUT_ROOT}/raw/vcf"
export SDS_SAMPLE_LIST_ROOT="${SDS_INPUT_ROOT}/freeze/sample_lists"
export SDS_SDS_INPUT_ROOT="${SDS_RESULTS_ROOT}/production/sds_input"
export SDS_SDS_OUTPUT_ROOT="${SDS_RESULTS_ROOT}/production/sds_output"
export SDS_DEMOGRAPHY_ROOT="${SDS_RESULTS_ROOT}/production/demography"
export SDS_GAMMA_ROOT="${SDS_RESULTS_ROOT}/production/gamma"
export SDS_RAW_HEADER_INTERSECTION_ROOT="${SDS_RESULTS_ROOT}/audit/raw_header_intersections"

export SDS_MS_ROOT="${SDS_EXTERNAL_ROOT}/ms"
export SDS_MS_SCRIPTS_DIR="${SDS_MS_ROOT}/scripts"
export SDS_MS_BINARY="${SDS_MS_ROOT}/msdir/ms"
export SDS_BACKWARD_SCRIPT="${SDS_MS_SCRIPTS_DIR}/backward.py"

export SDS_ENV_PREFIX="/abs/path/to/miniforge3/envs/sds"
export MINIFORGE_ROOT="/abs/path/to/miniforge3"
export SDS_PYTHON="${SDS_ENV_PREFIX}/bin/python"

# Transitional legacy roots for fallback lookup only
export SDS_LEGACY_CODE_ROOT="/abs/path/to/legacy/sds"
export SDS_LEGACY_BENCHMARK_ROOT="/abs/path/to/legacy/benchmark"
